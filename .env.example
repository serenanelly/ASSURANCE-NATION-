# Profil Spring : local (H2) | dev (PostgreSQL) | prod
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (profil dev)
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (min. 256 bits)
JWT_SECRET=AssuranceNationSecretKeyForJWTSigningMustBeAtLeast256BitsLong2026!

# CORS frontend
CORS_ORIGINS=http://localhost:3000

# Répertoire des justificatifs PDF
APP_PDF_OUTPUT_DIR=./data/justificatifs
